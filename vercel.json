{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "headers": [
    {
      "source": "/pix/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|pix/|favicon.ico|robots.txt|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}
